/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'sha256-SuZ2M7/jJz3OZ0cmH+E10piwhZGnrWPkhr0LA28mlpk='; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://services.swpc.noaa.gov https://api.weather.gc.ca https://api.open-meteo.com https://api.bigdatacloud.net https://nominatim.openstreetmap.org https://*.tile.openstreetmap.org https://demotiles.maplibre.org; worker-src 'self' blob:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'
  Cache-Control: no-cache, must-revalidate

# The catch-all above covers every SPA deep route (Pages serves index.html
# for /flightops etc., and _headers matches on request path). Specific
# assets below detach that rule (!) and set their own caching.

/sw.js
  ! Cache-Control
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/manifest.json
  ! Cache-Control
  Cache-Control: public, max-age=86400

/icon-192.svg
  ! Cache-Control
  Cache-Control: public, max-age=86400

/icon-512.svg
  ! Cache-Control
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  ! Cache-Control
  Cache-Control: public, max-age=86400

# Static build data — regenerated only when the research pipeline runs.
# stale-while-revalidate keeps repeat loads instant while picking up new
# deploys in the background.
/municipalities.json
  ! Cache-Control
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/tles.json
  ! Cache-Control
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

/assets/*
  ! Cache-Control
  Cache-Control: public, max-age=31536000, immutable
